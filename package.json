{
  "name": "sales-ai",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-tenant Sales AI SaaS (API + Worker + Web)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @sales-ai/api",
    "dev:api": "npm run dev -w @sales-ai/api",
    "dev:worker": "npm run dev -w @sales-ai/worker",
    "dev:web": "npm run dev -w @sales-ai/web",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

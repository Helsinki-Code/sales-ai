{
  "name": "sales-ai",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-tenant Sales AI SaaS (API + Worker + Web)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "pino": "^9.14.0"
  },
  "devDependencies": {
    "vercel": "^51.7.0"
  },
  "scripts": {
    "dev": "npm run dev -w @sales-ai/api",
    "dev:api": "npm run dev -w @sales-ai/api",
    "dev:worker": "npm run dev -w @sales-ai/worker",
    "dev:web": "npm run dev -w @sales-ai/web",
    "blog:images": "python scripts/generate-blog-images.py",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "stripe:catalog": "node scripts/create-stripe-catalog.mjs"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

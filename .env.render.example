# Production Render env template
NODE_ENV=production
API_PORT=10000
API_BASE_URL=https://api.sales-ai.app
REDIS_URL=redis://default:<password>@<host>:6379
BULLMQ_PREFIX=sales-ai
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE
INTERNAL_ENCRYPTION_KEY=64_HEX_CHARS
TAVILY_API_KEY=YOUR_TAVILY
PARALLEL_API_KEY=YOUR_PARALLEL_KEY
PARALLEL_BASE_URL=https://api.parallel.ai
PARALLEL_TIMEOUT_MS=120000
PARALLEL_FINDALL_GENERATOR_DEFAULT=core
PARALLEL_FINDALL_ESCALATION_GENERATOR=pro
PARALLEL_FINDALL_BETA_HEADER=findall-2025-09-15
PARALLEL_TASK_PROCESSOR=core
LEADS_ENGINE_MODE=parallel_v1
SALES_SKILLS_DIR=./vendor/ai-sales-team/skills
SALES_SCRIPTS_DIR=./vendor/ai-sales-team/scripts
